# ============================================================================
# COLLEGE BUS TRACKER - FRONTEND CONFIGURATION
# ============================================================================
# Copy this file to .env in the frontend directory and fill in your values
# NEVER commit .env to version control!

# ────────────────────────────────────────────────────────────────────────
# API & BACKEND
# ────────────────────────────────────────────────────────────────────────

# Backend API URL - Production URL for deployed apps
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# ────────────────────────────────────────────────────────────────────────
# GOOGLE MAPS - ⚠️ SECURITY: Never expose API key in frontend! Use backend proxy
# ────────────────────────────────────────────────────────────────────────
# Get key from: https://console.cloud.google.com/
# Create backend endpoint at /api/maps-proxy to avoid exposing key
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# ────────────────────────────────────────────────────────────────────────
# FIREBASE - Get from Firebase Console
# ────────────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_VAPID_KEY=YOUR_VAPID_KEY_FOR_PUSH_NOTIFICATIONS

# ────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ────────────────────────────────────────────────────────────────────────
VITE_ENABLE_PUSH_NOTIFICATIONS=true
VITE_ENABLE_ANALYTICS=true
VITE_API_URL=http://localhost:5000/api

# Socket.IO Server URL (for real-time updates)
VITE_SOCKET_URL=http://localhost:5000

# ────────────────────────────────────────────────────────────────────────
# GOOGLE MAPS API
# ────────────────────────────────────────────────────────────────────────

# Get your API key from: https://console.cloud.google.com
# Required APIs to enable:
#   1. Maps JavaScript API
#   2. Places API
#   3. Geocoding API
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ────────────────────────────────────────────────────────────────────────
# FIREBASE CONFIGURATION (if using Firebase Auth)
# ────────────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ────────────────────────────────────────────────────────────────────────
# APPLICATION SETTINGS
# ────────────────────────────────────────────────────────────────────────

VITE_APP_NAME=College Bus Tracker
VITE_APP_VERSION=2.0.0
VITE_ENVIRONMENT=development

# ────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS & DEBUG
# ────────────────────────────────────────────────────────────────────────

VITE_ENABLE_LOGGING=true
VITE_ENABLE_DEBUG=false
VITE_ENABLE_ANALYTICS=false

# ────────────────────────────────────────────────────────────────────────
# PRODUCTION DEPLOYMENT (Comment out development vars above)
# ────────────────────────────────────────────────────────────────────────

# VITE_API_URL=https://api.yourdomain.com/api
# VITE_SOCKET_URL=https://api.yourdomain.com
# VITE_GOOGLE_MAPS_API_KEY=your-production-key
# VITE_ENVIRONMENT=production

