# Firebase web app config — get these values from:
# Firebase console → Project settings (gear icon) → General → Your apps → Web app
# (If no web app is registered yet, click "</>" to add one — no hosting setup needed there.)
# Copy this file to .env and fill in the real values. NEVER commit .env.
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=bustracking-fe9fe.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=bustracking-fe9fe
VITE_FIREBASE_STORAGE_BUCKET=bustracking-fe9fe.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
