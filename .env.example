# ====================================
# BUS TRACKING SYSTEM - ENVIRONMENT VARIABLES
# ====================================

# SERVER CONFIGURATION
NODE_ENV=development
PORT=5000
HOST=localhost

# MONGODB CONNECTION
MONGODB_URI=mongodb://localhost:27017/bus-tracking
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/bus-tracking

# JWT & AUTH TOKENS
TOKEN_SECRET=your-super-secret-jwt-key-2024-change-in-production
PIN_SALT=your-pin-salt-2024-change-in-production

# CORS CONFIGURATION
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
# For production: https://yourdomain.com

# FIREBASE CONFIGURATION
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
# Or use FIREBASE_CONFIG_PATH=./serviceAccountKey.json

# GOOGLE MAPS API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# FRONTEND CONFIGURATION
VITE_SOCKET_URL=http://localhost:5000
VITE_API_URL=http://localhost:5000

# PRODUCTION FRONTEND
# VITE_SOCKET_URL=https://api.yourdomain.com
# VITE_API_URL=https://api.yourdomain.com

# LOG LEVEL
LOG_LEVEL=debug
# Production: LOG_LEVEL=info

# OPTIONAL: RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# OPTIONAL: GPS UPDATE INTERVAL (milliseconds)
GPS_UPDATE_INTERVAL=5000
