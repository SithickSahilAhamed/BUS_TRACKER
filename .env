# DEVELOPMENT ENVIRONMENT VARIABLES
NODE_ENV=development
PORT=5000
HOST=localhost

# MONGODB CONNECTION (Local or Atlas)
MONGODB_URI=mongodb://localhost:27017/bus-tracking

# JWT & AUTH TOKENS (Change these in production!)
TOKEN_SECRET=bus-tracker-dev-secret-key-2024
PIN_SALT=bus-tracker-pin-salt-2024

# CORS CONFIGURATION
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080

# GOOGLE MAPS API KEY
GOOGLE_MAPS_API_KEY=your-dev-google-maps-key

# FRONTEND CONFIGURATION
VITE_SOCKET_URL=http://localhost:5000
VITE_API_URL=http://localhost:5000

# LOG LEVEL
LOG_LEVEL=debug

# GPS UPDATE INTERVAL
GPS_UPDATE_INTERVAL=5000
