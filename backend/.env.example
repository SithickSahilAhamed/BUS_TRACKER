# ============================================================================
# COLLEGE BUS TRACKER — ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ─── SERVER ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── DATABASE ──────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/bus-tracking

# ─── SECURITY: TOKEN SECRETS (Must be >= 32 characters!) ──────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=your_long_random_token_secret_minimum_32_characters_required
PIN_SALT=your_long_random_pin_salt_minimum_16_characters

# ─── FIREBASE (Get from Firebase Console) ─────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# ─── FCM (Firebase Cloud Messaging) ────────────────────────────────────────
FCM_SENDER_ID=your-fcm-sender-id

# ─── CORS & ORIGIN ────────────────────────────────────────────────────────
# server.js reads CORS_ORIGIN (comma-separated, no trailing slash)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
# Production example:
# CORS_ORIGIN=https://your-frontend.vercel.app

# ─── ADMIN CREDENTIALS (Change for production!) ───────────────────────────
# Only used for initial setup, not for runtime authentication
ADMIN_EMAIL=admin@bustrack.com
ADMIN_PASSWORD=securepassword123

# ─── OPTIONAL: Logging Level ──────────────────────────────────────────────
LOG_LEVEL=info

# ─── OPTIONAL: Database Backup ─────────────────────────────────────────────
MONGODB_BACKUP_URL=mongodb+srv://user:pass@backup-cluster.mongodb.net/bus-tracking

# ─── OPTIONAL: SendGrid (for email notifications) ─────────────────────────
SENDGRID_API_KEY=your-sendgrid-key

# ─── OPTIONAL: Sentry (for error tracking) ───────────────────────────────
# SENTRY_DSN=https://key@o1234567.ingest.sentry.io/1234567
