rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Costs 1 read per evaluation — used only on cold paths (signup, claim,
    // admin ops). The hot GPS-write path below never calls this.
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return signedIn() && userData().role == 'admin';
    }

    function isActiveDriver() {
      return signedIn() && userData().role == 'driver' && userData().active == true;
    }

    function isMaintenance() {
      return signedIn() && userData().role == 'maintenance' && userData().active == true;
    }

    match /users/{uid} {
      // Drivers can read rider profiles too — needed for the waiting-student
      // count and boarding roster on their bus (PROJECT_SPEC.md section 3).
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin() || isActiveDriver());

      allow create: if
        // Self-signup: role limited to student/professor, fixed key set,
        // college email only — nobody can grant themselves admin or driver.
        (request.auth.uid == uid
          && request.resource.data.role in ['student', 'professor']
          && request.resource.data.active == true
          && request.resource.data.email.lower().matches('.*@act[.]edu[.]in$')
          && request.resource.data.keys().hasOnly(['name', 'email', 'role', 'active', 'createdAt']))
        // Admin creating a driver or maintenance profile (uid comes from secondary-app signup)
        || (isAdmin() && request.resource.data.role in ['driver', 'maintenance']
          && request.resource.data.email.lower().matches('.*@act[.]edu[.]in$'));

      allow update: if
        (request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'phone']))
        || isAdmin();

      allow delete: if isAdmin();
    }

    match /buses/{busId} {
      allow read: if signedIn();
      allow create, delete: if isAdmin();

      allow update: if isAdmin()
        // (a) Driver claims a bus (Start Trip). Only trip fields may change,
        // the claim must be for themselves, and the bus must be free (or
        // already theirs — allows re-claim after a phone crash).
        || (isActiveDriver()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['isActive', 'activeDriverId', 'activeDriverName', 'tripStartedAt', 'lastLocation', 'boardedStudentIds', 'updatedAt'])
            && request.resource.data.activeDriverId == request.auth.uid
            && (resource.data.activeDriverId == null
                || resource.data.activeDriverId == request.auth.uid))
        // (b) HOT PATH: the current claim-holder streams location, toggles
        // boarding, or ends the trip. Pure uid comparison — zero get() reads
        // per GPS write.
        || (signedIn()
            && resource.data.activeDriverId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['lastLocation', 'isActive', 'activeDriverId', 'activeDriverName', 'tripStartedAt', 'boardedStudentIds', 'updatedAt']))
        // (c) Maintenance "schedules maintenance" (PROJECT_SPEC.md section 5)
        // by setting the service-due date — nothing else on the bus doc.
        || (isMaintenance()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nextServiceDueDate', 'updatedAt']));
    }

    match /reports/{reportId} {
      // Incident/damage reports (PROJECT_SPEC.md section 3). Drivers file
      // them for admin to triage. Maintenance staff additionally get the
      // damage ones as "Repair Requests" (section 5) — not incidents, those
      // stay purely operational/admin.
      allow read: if isAdmin() || (isMaintenance() && resource.data.type == 'damage');
      allow delete: if isAdmin();

      allow update: if isAdmin()
        || (isMaintenance() && resource.data.type == 'damage'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'resolvedAt', 'repairNotes']));

      allow create: if isActiveDriver()
        && request.resource.data.driverId == request.auth.uid
        && request.resource.data.type in ['incident', 'damage']
        && request.resource.data.status == 'open'
        && request.resource.data.keys().hasOnly(
             ['type', 'category', 'description', 'busId', 'busNumber', 'driverId', 'driverName', 'status', 'createdAt']);
    }

    match /missedBusRequests/{requestId} {
      // A student requests an alternative bus; only admin approves/denies
      // (PROJECT_SPEC.md sections 2 + 4). The requester can also read their
      // own request to see its status.
      allow read: if isAdmin() || (signedIn() && resource.data.studentId == request.auth.uid);
      allow update, delete: if isAdmin();

      allow create: if signedIn()
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly(
             ['studentId', 'studentName', 'originalBusId', 'requestedBusId', 'requestedBusNumber', 'status', 'createdAt']);
    }

    match /entryExitLogs/{logId} {
      // Geofence crossings (PROJECT_SPEC.md section 4) — admin-only reading,
      // written only by the bus's own current driver. Rare (a couple of
      // writes per trip), so the extra get() here is not the hot GPS path.
      allow read, update, delete: if isAdmin();

      allow create: if isActiveDriver()
        && get(/databases/$(database)/documents/buses/$(request.resource.data.busId)).data.activeDriverId == request.auth.uid
        && request.resource.data.event in ['entry', 'exit']
        && request.resource.data.keys().hasOnly(['busId', 'busNumber', 'event', 'at']);
    }

    match /fuelRecords/{recordId} {
      // PROJECT_SPEC.md section 5 fuel management. History, so no update —
      // fix a mistake by admin deleting and re-adding.
      allow read, create: if isAdmin() || isMaintenance();
      allow delete: if isAdmin();
    }

    match /maintenanceRecords/{recordId} {
      // Covers section 5's Maintenance History, Tyre Management, and
      // Battery Management — one log with a category, not three collections.
      allow read, create: if isAdmin() || isMaintenance();
      allow delete: if isAdmin();
    }
  }
}
